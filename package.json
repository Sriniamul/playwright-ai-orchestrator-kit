{
  "name": "playwright-agent-orchestrator",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc --outDir dist",
    "status": "npm run build && node dist/status.js",
    "cleanup": "npm run build && node dist/cleanup.js",
    "discover": "npm run build && node dist/discover.js",
    "generate": "npm run build && node dist/orchestrator.js",
    "resume": "npm run build && node dist/orchestrator.js --resume",
    "plan": "npm run build && node dist/orchestrator.js --plan",
    "heal": "npm run build && node dist/heal.js",
    "test:generated": "npx playwright test tests/generated",
    "report": "npx playwright show-report",
    "export": "powershell -ExecutionPolicy Bypass -File export-last-run.ps1",
    "export:zip": "powershell -ExecutionPolicy Bypass -File export-last-run.ps1 -Zip"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@github/copilot": "^1.0.71",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
